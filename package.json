{
  "name": "cjsoftware-license-checker",
  "version": "1.1.0",
  "description": "Cross-platform application to check licensed software",
  "author": "Charles Jasthyn",
  "repository": "selrahcDC/cjsoftware-license-checker",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc && electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "build:mac": "npm run build && npx electron-builder --mac --x64 --arm64",
    "build:win": "npm run build && npx electron-builder --win --x64 --arm64"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "electron-vite": "^2.0.0",
    "png2icons": "^2.0.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
